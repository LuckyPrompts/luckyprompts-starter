# luckyprompts-starter — environment variables
# Copy this file to .env and fill in what you need.
# Local-only usage (Ollama) requires nothing here.

# ── Local models ──────────────────────────────────────────────────────────────

# Ollama host (default: localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Which local model to use by default
# Run `ollama list` to see what's installed
# OLLAMA_MODEL=mistral:7b

# LM Studio or any OpenAI-compatible local server
# LM_STUDIO_HOST=http://localhost:1234/v1
# LM_STUDIO_MODEL=your-model-name-from-lm-studio

# ── Cloud models (optional) ───────────────────────────────────────────────────

# Anthropic (Claude Haiku / Sonnet)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o)
# OPENAI_API_KEY=sk-...

# AWS Bedrock (Claude via AWS)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
